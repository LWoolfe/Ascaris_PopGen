#!/bin/bash
#SBATCH --job-name=miss_sweep
#SBATCH --partition=high_mem
#SBATCH --cpus-per-task=8
#SBATCH --mem=60G
#SBATCH --time=06:00:00
#SBATCH --output=miss_sweep.%j.out
#SBATCH --error=miss_sweep.%j.err

set -euo pipefail

source /users/lw01165/miniconda3/etc/profile.d/conda.sh
conda activate tools_env

ANALYSIS_DIR=/parallel_scratch/lw01165/05_analysis
IN_VCF=${ANALYSIS_DIR}/Ascaris.autosomes.SNPs.clean.vcf.gz
OUT_BASE=${ANALYSIS_DIR}/Ascaris.autosomes.SNPs.clean

echo "Input VCF: ${IN_VCF}"
echo "Output base: ${OUT_BASE}"

# Ensure tabix index exists
if [ ! -f "${IN_VCF}.tbi" ]; then
  echo "Index missing for ${IN_VCF} - creating..."
  bcftools index -t "${IN_VCF}"
fi

# --------------------------
# (1) Missingness summaries
# --------------------------
echo "Computing missingness per individual (.imiss)..."
vcftools --gzvcf "${IN_VCF}" --missing-indv --out "${OUT_BASE}"

echo "Computing missingness per site (.lmiss)..."
vcftools --gzvcf "${IN_VCF}" --missing-site --out "${OUT_BASE}"

IMISS="${OUT_BASE}.imiss"
LMISS="${OUT_BASE}.lmiss"

echo "Wrote: ${IMISS}"
echo "Wrote: ${LMISS}"

# -----------------------------------------
# (2) Summarize sample missingness/call rate
# -----------------------------------------
# .imiss columns typically: INDV  N_DATA  N_GENOTYPED  N_MISS  F_MISS
# call_rate = 1 - F_MISS
echo "Summarising sample call rate / missingness..."
SUM_TSV="${OUT_BASE}.imiss.summary.tsv"
awk 'BEGIN{OFS="\t"}
     NR==1{print "INDV","N_DATA","N_GENOTYPED","N_MISS","F_MISS","CALL_RATE"; next}
     {call=1-$5; print $1,$2,$3,$4,$5,call}' "${IMISS}" > "${SUM_TSV}"

echo "Top 10 worst samples by missingness (highest F_MISS):"
# sort numeric descending by F_MISS (col 5), skip header
tail -n +2 "${IMISS}" | sort -k5,5nr | head -n 10 | awk 'BEGIN{OFS="\t"}{print $1,$5}'

# ----------------------------------------------------
# (3) Make keep-lists for multiple sample thresholds
# ----------------------------------------------------
# These thresholds are MAX allowed missingness per sample (F_MISS).
# Adjust as you like.
SAMPLE_THRESHOLDS=(0.01 0.02 0.05 0.10)

echo "Creating keep-lists for sample missingness thresholds..."
for thr in "${SAMPLE_THRESHOLDS[@]}"; do
  KEEP_LIST="${OUT_BASE}.keep.samples.maxFmiss${thr}.txt"
  # keep samples with F_MISS <= thr
  awk -v t="${thr}" 'NR>1 && $5<=t {print $1}' "${IMISS}" > "${KEEP_LIST}"
  n_keep=$(wc -l < "${KEEP_LIST}")
  echo "  ${KEEP_LIST} (n_keep=${n_keep})"
done

# -------------------------------------------------------------------
# (4) Estimate site retention for multiple --max-missing cutoffs (X)
# -------------------------------------------------------------------
# For a given --max-missing X, sites are kept if F_MISS <= (1 - X)
SITE_THRESHOLDS=(0.95 0.90 0.85 0.80 0.70)

SITE_COUNT_TSV="${OUT_BASE}.lmiss.site_retention.tsv"
echo -e "max_missing\tmax_F_MISS_allowed\tkept_sites\ttotal_sites\tprop_kept" > "${SITE_COUNT_TSV}"

total_sites=$(awk 'NR>1{c++} END{print c+0}' "${LMISS}")

echo "Estimating retention for different site call-rate thresholds..."
for X in "${SITE_THRESHOLDS[@]}"; do
  # allowed missing fraction:
  # max_F = 1 - X
  maxF=$(awk -v x="${X}" 'BEGIN{printf "%.6f", (1-x)}')
  kept=$(awk -v m="${maxF}" 'NR>1 && $NF<=m {c++} END{print c+0}' "${LMISS}")
  prop=$(awk -v k="${kept}" -v t="${total_sites}" 'BEGIN{if(t>0) printf "%.6f", (k/t); else print "NA"}')
  echo -e "${X}\t${maxF}\t${kept}\t${total_sites}\t${prop}" >> "${SITE_COUNT_TSV}"
done

echo "Wrote: ${SITE_COUNT_TSV}"

echo "Done."

#!/usr/bin/env bash
set -euo pipefail

# 0) Make all_samples.txt (if not already made)
# bcftools query -l Ascaris.autosomes.SNPs.clean.vcf.gz > all_samples.txt

# 1) Pull out SRR3 / SRR8 lists from all samples
grep "^SRR3" all_samples.txt > all_SRR3.txt
grep "^SRR8" all_samples.txt > all_SRR8.txt

# 2) Remove all SRR3 and SRR8 from the full list
grep -v -E "^SRR3|^SRR8" all_samples.txt > non_SRR38_samples.txt

# 3) Make pools for random selection (exclude fixed keep IDs)
grep -v -F -f keep_SRR3_fixed.txt all_SRR3.txt > SRR3_pool.txt
grep -v -F -f keep_SRR8_fixed.txt all_SRR8.txt > SRR8_pool.txt

# 4) Randomly sample from the pools (change seeds if you want different draws)
shuf --random-source=<(yes 42) -n 10 SRR3_pool.txt > SRR3_random10.txt
shuf --random-source=<(yes 84) -n 15 SRR8_pool.txt > SRR8_random15.txt

# 5) Final SRR lists
cat keep_SRR3_fixed.txt SRR3_random10.txt > final_SRR3_samples.txt
cat keep_SRR8_fixed.txt SRR8_random15.txt > final_SRR8_samples.txt

# 6) Final balanced sample list
cat non_SRR38_samples.txt final_SRR3_samples.txt final_SRR8_samples.txt > balanced_samples.txt

# 7) Sanity checks
echo "Total samples in balanced_samples.txt:"
wc -l balanced_samples.txt

echo "SRR3 count:"
grep "^SRR3" balanced_samples.txt | wc -l

echo "SRR8 count:"
grep "^SRR8" balanced_samples.txt | wc -l

echo "Duplicate sample IDs (should be empty):"
sort balanced_samples.txt | uniq -d || true

