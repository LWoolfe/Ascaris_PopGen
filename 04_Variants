#!/bin/bash
#SBATCH --job-name=04c_qc_umap
#SBATCH --partition=high_mem
#SBATCH --output=/parallel_scratch/lw01165/04_Variants/04c_qc_umap.%j.out
#SBATCH --error=/parallel_scratch/lw01165/04_Variants/04c_qc_umap.%j.err
#SBATCH --time=04:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G

set -eo pipefail

# Helpful debugging if anything fails (prints failing line + command to .err)
trap 'echo "ERROR on line $LINENO"; echo "Last command: $BASH_COMMAND" >&2' ERR

source /users/lw01165/miniconda3/etc/profile.d/conda.sh
conda activate tools_env

# FIXED: this should be the directory that actually contains the VCFs you listed
WORKDIR=/parallel_scratch/lw01165/04_Variants/04a_merged

# NOTE: keep your original spelling here; just make sure the directory really exists
UMAPDIR=/parallel_scratch/lw01165/04_Variants/04c_uniquly_mappable_var

OUTDIR=/parallel_scratch/lw01165/04_Variants/04c_uniquly_mappable_var/QC
mkdir -p "${OUTDIR}"

OUTTSV="${OUTDIR}/retention_summary.tsv"

echo -e "TYPE\tSET\tRECORDS\tPASS\tNONPASS\tTSTV" > "${OUTTSV}"

# Helper: write one line of summary for a VCF
summarize_vcf () {
  local type="$1"
  local setname="$2"
  local vcf="$3"
  local do_tstv="$4"  # "yes" for SNP/MIXED, "no" for INDEL

  # If missing/empty, write a placeholder row but don't crash the whole job
  if [[ ! -s "${vcf}" ]]; then
    echo "WARN: missing/empty VCF: ${vcf}" >&2
    echo -e "${type}\t${setname}\t0\t0\t0\tNA" >> "${OUTTSV}"
    return 0
  fi

  # total records
  local records
  records=$(bcftools view -H "${vcf}" | wc -l)

  # PASS records (FILTER=PASS)
  local pass
  pass=$(bcftools view -f PASS -H "${vcf}" | wc -l)

  # NONPASS = total - pass
  local nonpass=$((records - pass))

  # Ts/Tv (only meaningful for SNP/MIXED; bcftools stats reports it)
  local tstv="NA"
  if [[ "${do_tstv}" == "yes" ]]; then
    # Best-effort: don't let bcftools stats failure kill the whole script
    tstv=$(
      bcftools stats -s - "${vcf}" 2>/dev/null \
        | awk -F'\t' '$1=="TSTV"{print $3; exit}' \
        || true
    )
    [[ -z "${tstv}" ]] && tstv="NA"
  fi

  echo -e "${type}\t${setname}\t${records}\t${pass}\t${nonpass}\t${tstv}" >> "${OUTTSV}"
}

############################
# Input VCFs (in WORKDIR)
############################
SNP_TAGGED="${WORKDIR}/merged_all_samples.SNPs.tagged.vcf.gz"
INDEL_TAGGED="${WORKDIR}/merged_all_samples.INDELs.tagged.vcf.gz"
MIXED_TAGGED="${WORKDIR}/merged_all_samples.MIXED.tagged.vcf.gz"

# Filtered files (if present)
SNP_FILTERED="${WORKDIR}/merged_all_samples.SNPs.filtered.vcf.gz"
INDEL_FILTERED="${WORKDIR}/merged_all_samples.INDELs.filtered.vcf.gz"
MIXED_FILTERED="${WORKDIR}/merged_all_samples.MIXED.filtered.vcf.gz"

# Uniquemap outputs
SNP_UMAP="${UMAPDIR}/merged_all_samples.SNPs.filtered.uniquemap.vcf.gz"
INDEL_UMAP="${UMAPDIR}/merged_all_samples.INDELs.filtered.uniquemap.vcf.gz"
MIXED_UMAP="${UMAPDIR}/merged_all_samples.MIXED.filtered.uniquemap.vcf.gz"

############################
# Sanity checks (fail fast with clear messages)
############################
echo "Checking presence of key inputs..." >&2
ls -lh "${SNP_TAGGED}" "${INDEL_TAGGED}" "${MIXED_TAGGED}" >&2
# Uniquemap files might legitimately be missing if that step hasn't run;
# we don't hard-fail here because summarize_vcf will emit WARN rows.
ls -lh "${SNP_UMAP}" "${INDEL_UMAP}" "${MIXED_UMAP}" >&2 || true

############################
# Summaries
############################

# TAGGED
summarize_vcf "SNPs"   "tagged"    "${SNP_TAGGED}"   "yes"
summarize_vcf "INDELs" "tagged"    "${INDEL_TAGGED}" "no"
summarize_vcf "MIXED"  "tagged"    "${MIXED_TAGGED}" "yes"

# FILTERED (PASS-only)
# If the *.filtered.vcf.gz files do not exist, compute filtered counts as PASS-only from the tagged file.
filtered_from_tagged () {
  local type="$1"
  local tagged="$2"
  local do_tstv="$3"

  local pass
  pass=$(bcftools view -f PASS -H "${tagged}" | wc -l)

  local tstv="NA"
  if [[ "${do_tstv}" == "yes" ]]; then
    tstv=$(
      bcftools stats -s - "${tagged}" 2>/dev/null \
        | awk -F'\t' '$1=="TSTV"{print $3; exit}' \
        || true
    )
    [[ -z "${tstv}" ]] && tstv="NA"
  fi

  # filtered set: records=PASS, pass=PASS, nonpass=0
  echo -e "${type}\tfiltered\t${pass}\t${pass}\t0\t${tstv}" >> "${OUTTSV}"
}

if [[ -f "${SNP_FILTERED}" ]]; then
  summarize_vcf "SNPs"   "filtered" "${SNP_FILTERED}"   "yes"
else
  filtered_from_tagged "SNPs" "${SNP_TAGGED}" "yes"
fi

if [[ -f "${INDEL_FILTERED}" ]]; then
  summarize_vcf "INDELs" "filtered" "${INDEL_FILTERED}" "no"
else
  filtered_from_tagged "INDELs" "${INDEL_TAGGED}" "no"
fi

if [[ -f "${MIXED_FILTERED}" ]]; then
  summarize_vcf "MIXED"  "filtered" "${MIXED_FILTERED}" "yes"
else
  filtered_from_tagged "MIXED" "${MIXED_TAGGED}" "yes"
fi

# UNIQUEMAP (already PASS-only by construction, but we still count PASS for consistency)
summarize_vcf "SNPs"   "uniquemap" "${SNP_UMAP}"   "yes"
summarize_vcf "INDELs" "uniquemap" "${INDEL_UMAP}" "no"
summarize_vcf "MIXED"  "uniquemap" "${MIXED_UMAP}" "yes"

echo "Done. Wrote: ${OUTTSV}"
#!/bin/bash
#SBATCH --job-name=sampleQC
#SBATCH --partition=high_mem
#SBATCH --cpus-per-task=8
#SBATCH --mem=60G
#SBATCH --time=24:00:00
#SBATCH --output=sampleQC.%j.out
#SBATCH --error=sampleQC.%j.err

set -eo pipefail

source /users/lw01165/miniconda3/etc/profile.d/conda.sh
conda activate tools_env

WORKDIR=/parallel_scratch/lw01165/04_Variants
INDIR=$WORKDIR/04c_uniquly_mappable_var
OUTDIR=$WORKDIR/04d_sample_QC

mkdir -p "$OUTDIR"
cd "$OUTDIR"

# 1) Create biallelic SNP QC dataset
vcftools --gzvcf "$INDIR/merged_all_samples.SNPs.filtered.uniquemap.vcf.gz" \
  --min-alleles 2 --max-alleles 2 \
  --recode --recode-INFO-all \
  --out SNPs.QCset

# 2) Per-individual missingness
vcftools --vcf SNPs.QCset.recode.vcf \
  --missing-indv \
  --out SNPs.QCset

# 3) Per-individual mean depth (low-cov sanity check)
vcftools --vcf SNPs.QCset.recode.vcf \
  --depth \
  --out SNPs.QCset

# 4) Heterozygosity / inbreeding coefficient
vcftools --vcf SNPs.QCset.recode.vcf \
  --het \
  --out SNPs.QCset

#!/bin/bash
#SBATCH --job-name=split_auto_sex
#SBATCH --partition=high_mem
#SBATCH --cpus-per-task=16
#SBATCH --mem=80G
#SBATCH --time=12:00:00
#SBATCH --output=split_auto_sex.%j.out
#SBATCH --error=split_auto_sex.%j.err

set -eo pipefail

source /users/lw01165/miniconda3/etc/profile.d/conda.sh
conda activate tools_env

WORKDIR=/parallel_scratch/lw01165/04_Variants/04d_sample_QC
cd $WORKDIR

INPUT_VCF=SNPs.QCset.recode.vcf
INPUT_GZ=SNPs.QCset.recode.vcf.gz

echo "Checking compression..."

# If gzipped file doesn't exist, bgzip it
if [ ! -f "$INPUT_GZ" ]; then
    echo "Compressing with bgzip..."
    bgzip -@ 8 $INPUT_VCF
fi

# Index if index does not exist
if [ ! -f "$INPUT_GZ.tbi" ]; then
    echo "Indexing VCF..."
    bcftools index -t $INPUT_GZ
fi

echo "Splitting autosomes..."

bcftools view -Oz \
